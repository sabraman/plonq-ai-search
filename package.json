{
	"name": "plonq-mini-app",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "next build",
		"build:vercel": "npx convex deploy --cmd 'npm run build'",
		"convex:dev": "convex dev",
		"convex:deploy": "convex deploy && next build",
		"dev": "next dev --turbopack",
		"dev:ssl": "next dev --experimental-https",
		"lint": "biome lint ./src",
		"lint:fix": "biome lint --write ./src",
		"format": "biome format ./src",
		"format:fix": "biome format --write ./src",
		"check": "biome check ./src",
		"check:fix": "biome check --write ./src",
		"start": "next start",
		"bot:poll": "node --env-file=.env.local --import tsx/esm src/scripts/bot/poll.ts",
		"bot:set-webhook": "node --env-file=.env.local --import tsx/esm src/scripts/bot/set-webhook.ts"
	},
