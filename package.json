  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "build:vercel": "NODE_OPTIONS=--localstorage-file=.convex-localstorage bunx convex deploy --cmd 'bun run build'",
    "convex:dev": "NODE_OPTIONS=--localstorage-file=.convex-localstorage convex dev",
    "convex:once": "NODE_OPTIONS=--localstorage-file=.convex-localstorage convex dev --once --typecheck enable",
    "convex:deploy": "NODE_OPTIONS=--localstorage-file=.convex-localstorage convex deploy && next build",
    "dev": "next dev --turbopack",
    "dev:ssl": "next dev --experimental-https",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "format": "biome format ./src",
    "format:fix": "biome format --write ./src",
    "check": "biome check ./src",
    "check:fix": "biome check --write ./src",
    "start": "next start"
